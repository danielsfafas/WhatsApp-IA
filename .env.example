# Copia a .env (no subas .env a git) y rellena los valores.
# Misma URL para Node y Python
REDIS_URL=redis://127.0.0.1:6379

# --- Recepcionista con IA (opcional) ---
# Con OPENAI_API_KEY el worker usa el modelo; si falta o falla, usa reglas en reception.py.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# RECEPCIONISTA_USE_AI=1
# Texto extra para el system prompt (horario, nombre clínica, políticas).
# RECEPCIONISTA_SYSTEM_EXTRA=

# Historial de chat para la IA (Redis). Más mensajes = más tokens.
# CHAT_MEMORY_MAX_MESSAGES=24
# CHAT_MEMORY_TTL_SEC=604800
# CHAT_MEMORY_KEY_PREFIX=wa:chatctx:

# --- Google Calendar (opcional; cuenta de servicio) ---
# 1) Google Cloud: activar "Google Calendar API" y crear cuenta de servicio + JSON.
# 2) En calendar.google.com → Configuración del calendario → Compartir con el email
#    xxx@proyecto.iam.gserviceaccount.com (permiso: cambiar eventos).
# 3) GOOGLE_CALENDAR_ID = suele ser el email del calendario donde compartiste.
# GOOGLE_CALENDAR_ENABLED=1
# GOOGLE_CALENDAR_SERVICE_ACCOUNT_FILE=google-calendar-sa.json
# GOOGLE_CALENDAR_ID=tu-clinica@gmail.com
# CALENDAR_TIMEZONE=America/Mexico_City
# CALENDAR_EVENT_DURATION_MINUTES=30
# OPENAI_CALENDAR_MODEL=gpt-4o-mini
# Si dateparser no interpreta la fecha del mensaje, segunda pasada con JSON (mismo OPENAI_API_KEY).
# CALENDAR_DATE_PARSE_FALLBACK=1
# OPENAI_CALENDAR_DATE_MODEL=gpt-4o-mini
# CALENDAR_DEDUP_TTL_SEC=604800
# Último evento creado por chat (reagendar: borrar por id sin depender del texto)
# CALENDAR_LAST_EVENT_KEY_PREFIX=wa:calevt:last:
# CALENDAR_LAST_EVENT_TTL_SEC=604800
# Horario de atención (validación + texto para la IA). Días: 0=lun … 6=dom
# CLINIC_OPEN_HOUR=9
# CLINIC_CLOSE_HOUR=18
# CLINIC_WEEKDAYS=0,1,2,3,4
# Receso de comida (sin citas), hora 24h. Ej. 14 y 15 = 14:00–15:00
# CLINIC_LUNCH_START_HOUR=14
# CLINIC_LUNCH_END_HOUR=15
# Paso al listar huecos libres y máximo de sugerencias en el prompt
# CALENDAR_SUGGESTION_STEP_MINUTES=30
# CALENDAR_MAX_SUGGESTION_SLOTS=8
